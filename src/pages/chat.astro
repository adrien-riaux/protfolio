---
import Layout from '../layouts/Layout.astro';
import ChatWidget from '../components/ChatWidget.tsx';
---

<Layout title="Portfolio | Chat" description="Ask the portfolio AI assistant about projects, skills, and achievements.">
  <section class="mb-6">
    <span class="brand-pill">AI Assistant</span>
    <h1 class="mt-4 text-3xl font-bold text-ink">Ask me anything about my work</h1>
    <p class="mt-2 max-w-2xl text-ink/75">
      This assistant is grounded in this portfolio context and answers in a concise, first-person voice.
    </p>
  </section>

  <ChatWidget client:load />
</Layout>
