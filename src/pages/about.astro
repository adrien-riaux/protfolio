---
import Layout from '../layouts/Layout.astro';
import { readProfileMarkdown } from '../lib/data';

const profile = await readProfileMarkdown();
const sections = profile
  .split(/\n\n+/)
  .map((part) => part.trim())
  .filter(Boolean);
---

<Layout title="Portfolio | About" description="About page generated from portfolio profile context.">
  <section class="card-surface p-8">
    <span class="brand-pill">About</span>
    <h1 class="mt-4 text-3xl font-bold text-ink">Professional Profile</h1>
    <div class="mt-6 space-y-4 leading-7 text-ink/85">
      {sections.map((section) => (
        <p>{section}</p>
      ))}
    </div>
  </section>
</Layout>
