---
import Layout from '../layouts/Layout.astro';

const experiences = [
  {
    period: 'Current',
    role: 'Machine Learning Engineer',
    company: 'Dior (LVMH)',
    description: `At Dior, I build robust MLOps infrastructure and generative AI systems. My focus is on designing scalable, production-ready architectures that support the full lifecycle of ML and GenAI products — from experimentation through to deployment and monitoring — meeting the high reliability standards of a leading luxury house.`
  },
  {
    period: 'Previous',
    role: 'Senior Data Scientist',
    company: 'Equancy',
    description: `During my three years at Equancy, I worked embedded within top-tier client teams (including Chanel, LVMH, Vinci, and Maisons du Monde) to deliver end-to-end ML solutions. I tackled diverse challenges from constrained optimization and forecasting to building scalable RAG architectures and multi-agent systems. Acting as a tech lead, I drove architectural decisions, mentored juniors, and deployed maintainable systems across GCP, Azure, and on-premise environments using Python, Docker, and standard CI/CD pipelines.`
  }
];
---

<Layout
  title="Adrien Riaux | Machine Learning Engineer"
  description="Machine Learning Engineer in Paris building scalable ML and GenAI systems."
>
  <section id="hero" class="card-surface relative overflow-hidden px-6 py-16 sm:px-10">
    <div class="pointer-events-none absolute -right-20 -top-16 h-72 w-72 rounded-full bg-moss/15 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-moss/10 blur-3xl"></div>

    <h1 class="mt-6 text-4xl font-bold leading-tight text-ink sm:text-5xl">Hi, I'm Adrien Riaux</h1>
    <p class="mt-3 text-lg text-moss sm:text-xl">
      Machine Learning Engineer
    </p>
    <p class="mt-6 max-w-3xl text-base leading-7 text-ink/80 sm:text-lg">
      Building scalable machine learning and generative AI systems that translate complex data into real-world business impact.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3 text-sm">
      <a
        href="https://www.linkedin.com/in/adrien-riaux"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com/adrien-riaux"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        GitHub
      </a>
      <a
        href="https://www.kaggle.com/adrienriaux"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        Kaggle
      </a>
      <a
        href="https://huggingface.co/adrien-riaux"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        Hugging Face
      </a>
      <a
        href="https://medium.com/@adrien.riaux"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        Medium
      </a>
    </div>
  </section>

  <section id="about" class="mt-10 card-surface px-6 py-10 sm:px-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">About Me</h2>
    <p class="mt-4 max-w-4xl leading-7 text-ink/80">
      I am a Machine Learning Engineer with expertise spanning classical ML, MLOps, and generative AI. With a dual background in engineering and business, I focus on bridging deep technical foundations with measurable business impact. 
      <br /><br />
      Over the years, I've worked embedded within demanding luxury and retail teams — including Chanel, LVMH, Vinci, and Maisons du Monde — progressing from building core ML models to designing scalable RAG architectures and multi-agent systems. Prioritizing production-readiness and maintainability, I specialize in designing systems that turn complex data challenges into robust, real-world solutions.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      <span class="rounded-full border border-moss/40 bg-moss/10 px-3 py-1 text-sm font-semibold text-moss">
        GCP Professional ML Engineer
      </span>
      <span class="rounded-full border border-moss/40 bg-moss/10 px-3 py-1 text-sm font-semibold text-moss">
        TensorFlow Developer
      </span>
      <span class="rounded-full border border-moss/40 bg-moss/10 px-3 py-1 text-sm font-semibold text-moss">
        Dataiku Practitioner
      </span>
    </div>
  </section>

  <section id="experience" class="mt-10 card-surface px-6 py-10 sm:px-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">Experience</h2>
    <ol class="relative mt-8 before:absolute before:bottom-3 before:left-[6px] before:top-3 before:w-px before:bg-moss/45">
      {experiences.map((item) => (
        <li class="relative mb-7 grid grid-cols-[24px_1fr] gap-4 last:mb-0">
          <span class="relative z-10 mt-5 h-3 w-3 rounded-full bg-moss shadow-[0_0_0_5px_rgba(44,230,128,0.18)]"></span>
          <article class="card-surface rounded-2xl p-5 transition hover:border-moss/35 hover:shadow-[0_10px_28px_rgba(44,230,128,0.08)]">
            <p class="text-xs font-semibold uppercase tracking-wide text-moss">{item.period}</p>
            <h3 class="mt-1 text-xl font-bold text-ink">{item.role}</h3>
            <p class="mt-1 text-sm text-ink/75">{item.company}</p>
            <p class="mt-3 leading-7 text-ink/80">{item.description}</p>
          </article>
        </li>
      ))}
    </ol>
  </section>

  <section id="contact" class="mt-10 card-surface px-6 py-10 sm:px-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">Contact</h2>
    <p class="mt-3 text-ink/80">
      Email: <a href="mailto:adrien.riaux@efrei.net" class="font-semibold text-moss hover:underline">adrien.riaux@efrei.net</a>
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="mailto:adrien.riaux@efrei.net"
        class="rounded-full border border-moss/45 bg-moss/10 px-5 py-2.5 text-sm font-semibold text-moss transition hover:bg-moss/15"
      >
        Send an email
      </a>
      <a
        href="/chat"
        class="rounded-full border border-moss/45 bg-moss/10 px-5 py-2.5 text-sm font-semibold text-moss transition hover:bg-moss/15"
      >
        Chat with my AI assistant
      </a>
    </div>
  </section>
</Layout>
