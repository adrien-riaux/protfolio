---
import Layout from '../layouts/Layout.astro';

const highlights = [
  {
    title: 'Production ML Engineering',
    body: 'Designing scalable systems from experimentation to reliable deployment in cloud-native stacks.'
  },
  {
    title: 'GenAI & RAG',
    body: 'Shipping practical LLM applications focused on business relevance, performance, and maintainability.'
  },
  {
    title: 'MLOps Mindset',
    body: 'Building reusable templates, CI/CD-first workflows, and reproducible pipelines for delivery speed.'
  }
];

const experienceHighlights = [
  'Equancy x LVMH: RAG API with FastAPI, Docker, Cloud Run, and reusable MLOps templates.',
  'Equancy x Chanel: OR-Tools allocation, spatial clustering, and OCR-powered data workflows.',
  'Equancy x Maisons du Monde: GenAI sentiment analysis with Gemini API.',
  'Equancy Internal: news agent with LangGraph, Docker, and GitLab CI/CD deployment.'
];

const quickSections = [
  { id: 'hero', label: 'Hero' },
  { id: 'about', label: 'About' },
  { id: 'highlights', label: 'Highlights' },
  { id: 'experience', label: 'Experience' },
  { id: 'contact', label: 'Contact' }
];
---

<Layout
  title="Adrien Riaux | Machine Learning Engineer"
  description="Machine Learning Engineer in Paris building scalable ML and GenAI systems."
>
  <section id="hero" class="card-surface relative overflow-hidden px-6 py-16 sm:px-10">
    <div class="pointer-events-none absolute -right-20 -top-16 h-72 w-72 rounded-full bg-moss/15 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-24 -left-16 h-72 w-72 rounded-full bg-moss/10 blur-3xl"></div>

    <p class="brand-pill">Paris, France</p>
    <h1 class="mt-6 text-4xl font-bold leading-tight text-ink sm:text-5xl">Hi, I'm Adrien Riaux</h1>
    <p class="mt-3 text-lg text-moss sm:text-xl">
      Machine Learning Engineer | GCP Professional | GenAI &amp; MLOps Enthusiast
    </p>
    <p class="mt-6 max-w-3xl text-base leading-7 text-ink/80 sm:text-lg">
      I build scalable ML systems and generative AI applications, transforming complex data into
      production-ready business solutions.
    </p>

    <div class="mt-8 flex flex-wrap items-center gap-3">
      <a
        href="/achievements"
        class="rounded-full bg-moss px-5 py-2.5 text-sm font-semibold text-sand transition hover:bg-moss/90"
      >
        View Projects
      </a>
      <a
        href="mailto:adrien.riaux@efrei.net"
        class="rounded-full border border-ink/30 bg-sand/70 px-5 py-2.5 text-sm font-semibold text-ink transition hover:border-moss hover:text-moss"
      >
        Contact Me
      </a>
      <a
        href="/chat"
        class="rounded-full border border-moss/45 bg-moss/10 px-5 py-2.5 text-sm font-semibold text-moss transition hover:bg-moss/15"
      >
        Open AI Chat
      </a>
    </div>

    <div class="mt-8 flex flex-wrap items-center gap-3 text-sm">
      <a
        href="https://www.linkedin.com"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        LinkedIn
      </a>
      <a
        href="https://github.com"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        GitHub
      </a>
      <a
        href="https://www.kaggle.com"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        Kaggle
      </a>
      <a
        href="https://huggingface.co"
        target="_blank"
        rel="noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-ink/20 bg-sand/70 px-3 py-2 text-ink transition hover:border-moss hover:text-moss"
      >
        Hugging Face
      </a>
    </div>
  </section>

  <section id="about" class="mt-10 card-surface px-6 py-10 sm:px-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">About Me</h2>
    <p class="mt-4 max-w-4xl leading-7 text-ink/80">
      I am a Machine Learning Engineer with an engineering background from EFREI Paris and ENSIMAG,
      complemented by a double competence in business from Grenoble Ecole de Management. I focus on
      technical clarity, practical architecture, and measurable outcomes.
    </p>
    <div class="mt-6 flex flex-wrap gap-2">
      <span class="rounded-full border border-moss/40 bg-moss/10 px-3 py-1 text-sm font-semibold text-moss">
        TensorFlow Developer
      </span>
      <span class="rounded-full border border-moss/40 bg-moss/10 px-3 py-1 text-sm font-semibold text-moss">
        GCP Professional ML Engineer
      </span>
    </div>
  </section>

  <section id="highlights" class="mt-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">What I Focus On</h2>
    <div class="mt-6 grid gap-5 md:grid-cols-3">
      {highlights.map((item) => (
        <article class="card-surface p-6">
          <h3 class="text-xl font-bold text-ink">{item.title}</h3>
          <p class="mt-3 leading-7 text-ink/80">{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="experience" class="mt-10 card-surface px-6 py-10 sm:px-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">Experience Snapshot</h2>
    <ul class="mt-5 space-y-3 text-ink/80">
      {experienceHighlights.map((line) => (
        <li class="rounded-xl border border-ink/15 bg-sand/75 px-4 py-3">{line}</li>
      ))}
    </ul>
    <div class="mt-6">
      <a
        href="/achievements"
        class="inline-flex rounded-full border border-ink/25 px-5 py-2 text-sm font-semibold text-ink transition hover:border-moss hover:text-moss"
      >
        Explore full achievements
      </a>
    </div>
  </section>

  <section id="contact" class="mt-10 card-surface px-6 py-10 sm:px-10">
    <h2 class="text-2xl font-bold text-ink sm:text-3xl">Contact</h2>
    <p class="mt-3 text-ink/80">
      Email: <a href="mailto:adrien.riaux@efrei.net" class="font-semibold text-moss hover:underline">adrien.riaux@efrei.net</a>
    </p>
    <div class="mt-6 flex flex-wrap gap-3">
      <a
        href="mailto:adrien.riaux@efrei.net"
        class="rounded-full bg-moss px-5 py-2.5 text-sm font-semibold text-sand transition hover:bg-moss/90"
      >
        Send an email
      </a>
      <a
        href="/chat"
        class="rounded-full border border-moss/45 bg-moss/10 px-5 py-2.5 text-sm font-semibold text-moss transition hover:bg-moss/15"
      >
        Chat with my AI assistant
      </a>
    </div>
  </section>

  <details class="fixed bottom-5 right-5 z-20 xl:hidden">
    <summary class="cursor-pointer rounded-full border border-moss/40 bg-sand/85 px-4 py-2 text-sm font-semibold text-moss">
      Quick jump
    </summary>
    <div class="mt-2 min-w-[170px] rounded-2xl border border-ink/20 bg-sand/95 p-3 text-sm">
      <ul class="space-y-1.5">
        {quickSections.map((section) => (
          <li>
            <a class="text-ink transition hover:text-moss" href={`#${section.id}`}>{section.label}</a>
          </li>
        ))}
      </ul>
    </div>
  </details>

  <aside class="fixed right-6 top-1/2 z-20 hidden w-44 -translate-y-1/2 rounded-2xl border border-ink/15 bg-sand/85 p-4 xl:block">
    <p class="text-xs font-semibold uppercase tracking-wide text-moss">Quick jump</p>
    <ul class="mt-3 space-y-2 text-sm">
      {quickSections.map((section) => (
        <li>
          <a class="text-ink/85 transition hover:text-moss" href={`#${section.id}`}>{section.label}</a>
        </li>
      ))}
    </ul>
  </aside>
</Layout>
