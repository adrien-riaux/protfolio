---
interface Props {
  title: string;
  summary: string;
  metrics: Array<{ label: string; value: string | number }>;
  links?: Array<{ label: string; href: string; meta?: string }>;
  link?: string;
}

const { title, summary, metrics, links = [], link } = Astro.props;
---

<article class="card-surface p-6">
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-xl font-bold text-ink">{title}</h3>
      <p class="mt-1 text-sm text-ink/75">{summary}</p>
      {links.length > 0 && (
        <ul class="mt-3 space-y-2">
          {links.map((item) => (
            <li>
              <a
                href={item.href}
                target="_blank"
                rel="noreferrer"
                class="inline-flex items-center gap-2 text-sm font-semibold text-moss transition hover:text-gold"
              >
                <span>{item.label}</span>
                {item.meta && <span class="text-xs font-medium text-ink/55">{item.meta}</span>}
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
    {link && (
      <a
        class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-moss/40 bg-moss/10 text-moss transition hover:bg-moss/16"
        href={link}
        target="_blank"
        rel="noreferrer"
        aria-label={`Open ${title} link`}
        title="Open link"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 14L21 3m0 0h-7m7 0v7" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M21 14v5a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5" />
        </svg>
      </a>
    )}
  </div>

  <ul class="mt-5 grid gap-3 sm:grid-cols-2">
    {metrics.map((metric) => (
      <li class="rounded-xl border border-ink/10 bg-sand/55 p-3">
        <p class="text-xs uppercase tracking-wider text-ink/55">{metric.label}</p>
        <p class="mt-1 text-lg font-bold text-ink">{metric.value}</p>
      </li>
    ))}
  </ul>
</article>
