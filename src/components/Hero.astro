---
const owner = import.meta.env.PUBLIC_OWNER_NAME ?? 'Your Name';
const tagline = import.meta.env.PUBLIC_OWNER_TAGLINE ?? 'Engineer building practical software with measurable impact.';
---

<section class="grid gap-8 md:grid-cols-[1.4fr_1fr] md:items-end">
  <div class="card-surface p-8">
    <span class="brand-pill">Portfolio</span>
    <h1 class="mt-4 text-4xl font-bold leading-tight text-ink md:text-5xl">{owner}</h1>
    <p class="mt-3 max-w-2xl text-lg text-ink/80">{tagline}</p>
    <div class="mt-6 flex flex-wrap gap-3 text-sm font-semibold">
      <a class="rounded-full bg-moss px-5 py-2 text-white transition hover:bg-moss/90" href="/chat">Ask the AI</a>
      <a class="rounded-full border border-ink/20 px-5 py-2 text-ink transition hover:border-moss hover:text-moss" href="/achievements">View achievements</a>
    </div>
  </div>
  <aside class="card-surface p-6">
    <h2 class="text-sm font-bold uppercase tracking-wider text-ink/60">Quick focus</h2>
    <ul class="mt-4 space-y-2 text-sm text-ink/85">
      <li>Build-time fetched engineering profile data</li>
      <li>Lean static-first architecture with selective interactivity</li>
      <li>AI portfolio assistant powered by TogetherAI</li>
    </ul>
  </aside>
</section>
