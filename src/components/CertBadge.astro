---
import type { Certification } from '../lib/types';

interface Props {
  cert: Certification;
}

const { cert } = Astro.props;
---

<article class="card-surface overflow-hidden">
  <img src={cert.badgeImage} alt={`${cert.title} badge`} class="aspect-[16/10] w-full object-cover" loading="lazy" />
  <div class="p-4">
    <h3 class="text-lg font-bold text-ink">{cert.title}</h3>
    <p class="mt-1 text-sm text-ink/75">{cert.issuer}</p>
    <a class="mt-3 inline-block text-sm font-semibold text-moss hover:underline" href={cert.verifyUrl} target="_blank" rel="noreferrer">
      Verify credential
    </a>
  </div>
</article>
