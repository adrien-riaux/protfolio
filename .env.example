# Copy this file to .env.local and fill in your values
# Never commit .env.local to git!

# === REQUIRED ===
# Get your free key at https://api.together.ai → API Keys
TOGETHER_API_KEY=your_together_api_key_here

# === YOUR PLATFORM USERNAMES ===
GITHUB_USERNAME=your_github_username
STACKOVERFLOW_USER_ID=12345678
KAGGLE_USERNAME=your_kaggle_username

# === OPTIONAL: Higher API rate limits ===
GITHUB_TOKEN=ghp_your_token_here
STACKOVERFLOW_KEY=your_so_key_here

# === DISPLAY (PUBLIC_ prefix exposes to browser in Astro) ===
PUBLIC_OWNER_NAME="Your Full Name"
PUBLIC_OWNER_TAGLINE="Your tagline here"
PUBLIC_SITE_URL=https://yoursite.vercel.app
